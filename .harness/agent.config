{
  "name": "Harness治理Agent",
  "rules": [
    "严格遵守 .harness/rules",
    "读取 .harness/context 所有上下文",
    "生成后自动执行格式与测试检查",
    "禁止修改 .harness 规则文件"
  ],
  "context": [
    "arch.md",
    "api.md",
    "tech.md"
  ],
  "permissions": {
    "read": ["src/", ".harness/"],
    "write": ["src/"],
    "execute": [".harness/scripts/"]
  }
}